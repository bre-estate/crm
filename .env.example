# ============ Supabase ============
# Lấy từ Supabase Dashboard -> Project Settings -> API:
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Lấy từ Supabase Dashboard -> Project Settings -> Database -> Connection string
# (chọn "Transaction pooler" cho ap-southeast-1):
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
